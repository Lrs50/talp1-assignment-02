{
  "name": "tests",
  "version": "1.0.0",
  "scripts": {
    "test": "cd ../backend && cucumber-js --require '../tests/step_definitions/students.js' --require '../tests/step_definitions/assessments.js' '../tests/features/students.feature' '../tests/features/assessments.feature'",
    "test:summary": "cd ../backend && cucumber-js --require '../tests/step_definitions/students.js' --require '../tests/step_definitions/assessments.js' '../tests/features/students.feature' '../tests/features/assessments.feature' 2>&1 | tail -10",
    "test:students": "cd ../backend && cucumber-js --require '../tests/step_definitions/students.js' '../tests/features/students.feature'",
    "test:students:summary": "cd ../backend && cucumber-js --require '../tests/step_definitions/students.js' '../tests/features/students.feature' 2>&1 | tail -5",
    "test:assessments": "cd ../backend && cucumber-js --require '../tests/step_definitions/assessments.js' '../tests/features/assessments.feature'",
    "test:ui": "cd ../backend && cucumber-js --require '../tests/step_definitions/ui-setup.js' --require '../tests/step_definitions/students.ui.js' --require '../tests/step_definitions/assessments.ui.js' '../tests/features/students.feature' '../tests/features/assessments.feature'",
    "test:ui:students": "cd ../backend && cucumber-js --require '../tests/step_definitions/ui-setup.js' --require '../tests/step_definitions/students.ui.js' '../tests/features/students.feature'",
    "test:ui:assessments": "cd ../backend && cucumber-js --require '../tests/step_definitions/ui-setup.js' --require '../tests/step_definitions/assessments.ui.js' '../tests/features/assessments.feature'",
    "test:failed": "cd ../backend && cucumber-js --require '../tests/step_definitions/students.js' '../tests/features/**/*.feature' 2>&1 | grep -E '^(\\d+\\)|✔|✖|\\?)'",
    "test:watch": "cucumber-js --watch"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^9.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.0.0",
    "selenium-webdriver": "^4.14.0",
    "tsconfig-paths": "^4.2.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^2.0.0",
    "chai": "^4.3.0",
    "@types/chai": "^4.3.0"
  }
}
